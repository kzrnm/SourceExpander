<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="../../SourceExpander.Embedder/build/SourceExpander.Embedder.props" />
  <PropertyGroup>
    <TargetFrameworks>net10.0;netstandard2.1;netstandard2.0</TargetFrameworks>

    <SourceExpander_Embedder_EmbeddingType>raw</SourceExpander_Embedder_EmbeddingType>
    <SourceExpander_Embedder_PackJson Condition="'$(TargetFramework)' != 'netstandard2.0'">true</SourceExpander_Embedder_PackJson>
    <SourceExpander_Embedder_Enabled Condition="'$(TargetFramework)' == 'netstandard2.1'">false</SourceExpander_Embedder_Enabled>
    <OutputPath>$(MSBuildProjectDirectory)/bin</OutputPath>
    <ContinuousIntegrationBuild>false</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../SourceExpander.Embedder/SourceExpander.Embedder.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <OutputItemType>Analyzer</OutputItemType>
    </ProjectReference>
  </ItemGroup>

  <Import Project="../../SourceExpander.Embedder/build/SourceExpander.Embedder.targets" />
</Project>
