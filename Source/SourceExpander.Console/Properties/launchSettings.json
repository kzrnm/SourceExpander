{
  "profiles": {
    "Output file": {
      "commandName": "Project",
      "commandLineArgs": "../Sandbox/SampleApp/Program.cs -o obj/combined.csx",
      "workingDirectory": "$(ProjectDir)"
    },
    "Output console": {
      "commandName": "Project",
      "commandLineArgs": "../Sandbox/SampleApp/Program.cs",
      "workingDirectory": "$(ProjectDir)"
    },
    "Dependency Library": {
      "commandName": "Project",
      "commandLineArgs": "dependency ../Sandbox/SampleLibrary/SampleLibrary.csproj -p",
      "workingDirectory": "$(ProjectDir)"
    },
    "Dependency App": {
      "commandName": "Project",
      "commandLineArgs": "dependency ../Sandbox/SampleApp/Program.cs",
      "workingDirectory": "$(ProjectDir)"
    },
    "ExpandAll": {
      "commandName": "Project",
      "commandLineArgs": "expand-all ../Sandbox/SampleApp/SampleApp.csproj",
      "workingDirectory": "$(ProjectDir)"
    },
    "LibraryList": {
      "commandName": "Project",
      "commandLineArgs": "library-list ../Sandbox/SampleLibrary/SampleLibrary.csproj",
      "workingDirectory": "$(ProjectDir)"
    },
    "Embedded": {
      "commandName": "Project",
      "commandLineArgs": "embedded ../Sandbox/SampleLibrary/bin/Debug/net10.0/SampleLibrary.dll --output ../Sandbox/SampleLibrary/bin/Debug/net10.0/SampleLibrary2.dll",
      "workingDirectory": "$(ProjectDir)"
    },
    "no args": {
      "commandName": "Project",
      "workingDirectory": "$(ProjectDir)"
    }
  }
}