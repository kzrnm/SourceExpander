<Project>
  <Target Name="SourceExpanderNoGeneratePackageOnBuild"
          BeforeTargets="BeforeBuild">
    <Error Condition="'$(SourceExpander_PackJson_Enabled)' == 'true' And '$(GeneratePackageOnBuild)' == 'true'" Code="SourceEmbeddingPackJson0001" Text="'GeneratePackageOnBuild' must be false" />
  </Target>
  <!-- Write json and props/targets after build -->
  <Target Name="SourceExpanderWriteJson"
          AfterTargets="AfterBuild"
          Condition="'$(SourceExpander_PackJson_Enabled)' == 'true' And '$(_SourceExpander_Rebuilding)' != 'true'">
    <Message Importance="high" Text="SourceExpander: write embedded data json of '$(AssemblyName)' [$(TargetFramework)]" />
    <MakeDir Directories="$(TargetDir)SourceExpander.build" ContinueOnError="true" />

    <PropertyGroup>
      <_SourceExpander_PackageIdTag>$(PackageId.Replace('.', '_'))</_SourceExpander_PackageIdTag>
      <_SourceExpander_PackageSourceTag>$(_SourceExpander_PackageIdTag)_Source</_SourceExpander_PackageSourceTag>
      <SourceExpander_JsonName>$(TargetName)_SourceExpander.Embedded.json</SourceExpander_JsonName>
    </PropertyGroup>

    <ReadEmbeddedData AssemblyPath="$(TargetPath)" OutputPath="$(TargetDir)SourceExpander.build/$(SourceExpander_JsonName)" />
  </Target>

  <Target Name="SourceExpanderDefineProps"
          AfterTargets="SourceExpanderWriteJson"
          Condition="'$(SourceExpander_PackJson_Enabled)' == 'true' And '$(_SourceExpander_Rebuilding)' != 'true' And '$(SourceExpander_PackJsonProps_Enabled)' == 'true'">
    <Message Importance="high" Text="SourceExpander: Add '$(PackageId).props' [$(TargetFramework)]" />
    <PropertyGroup>
      <PackPropsPath Condition="'$(PackPropsPath)'==''">$(TargetDir)SourceExpander.build/$(PackageId).props</PackPropsPath>
      <PackPropsBody>
        <![CDATA[
<Project>
  <PropertyGroup>
    <$(_SourceExpander_PackageSourceTag)>%24(MSBuildThisFileDirectory)$(SourceExpander_JsonName)</$(_SourceExpander_PackageSourceTag)>
    <$(_SourceExpander_PackageSourceTag)_Visible>false</$(_SourceExpander_PackageSourceTag)_Visible>
  </PropertyGroup>
</Project>
      ]]>
      </PackPropsBody>
    </PropertyGroup>
    <WriteLinesToFile File="$(PackPropsPath)" Lines="$(PackPropsBody)" Overwrite="true" WriteOnlyWhenDifferent="true" />
  </Target>
  <Target Name="SourceExpanderDefineTargets"
          AfterTargets="SourceExpanderWriteJson"
          Condition="'$(SourceExpander_PackJson_Enabled)' == 'true' And '$(_SourceExpander_Rebuilding)' != 'true' And '$(SourceExpander_PackJsonTargets_Enabled)' == 'true'">
    <Message Importance="high" Text="SourceExpander: Add '$(PackageId).targets' [$(TargetFramework)]" />
    <PropertyGroup>
      <PackTargetsPath Condition="'$(PackTargetsPath)'==''">$(TargetDir)SourceExpander.build/$(PackageId).targets</PackTargetsPath>
      <PackTargetsBody>
        <![CDATA[
<Project>
  <ItemGroup Condition="'%24(SourceExpander_Generator)'=='true' And Exists('%24($(_SourceExpander_PackageSourceTag))')">
    <AdditionalFiles LinkBase="Properties/SourceExpander.Embedded"
      Include="%24($(_SourceExpander_PackageSourceTag))"
      Visible="%24($(_SourceExpander_PackageSourceTag)_Visible)" />
  </ItemGroup>
</Project>
      ]]>
      </PackTargetsBody>
    </PropertyGroup>
    <WriteLinesToFile File="$(PackTargetsPath)" Lines="$(PackTargetsBody)" Overwrite="true" WriteOnlyWhenDifferent="true" />
  </Target>

  <!-- Add package files -->
  <Target Name="SourceExpanderPackMetadata" Condition="'$(SourceExpander_PackJson_Enabled)' == 'true'">
    <Message Importance="high" Text="SourceExpander: Add package files of '$(AssemblyName)' [$(TargetFramework)]" />
    <ItemGroup>
      <TfmSpecificPackageFile
        Include="$(TargetDir)SourceExpander.build/*"
        PackagePath="buildTransitive/$(TargetFramework)"
        IncludeInPackage="true" CopyToOutputDirectory="Never" />
    </ItemGroup>
  </Target>
  <Target Name="SourceExpanderSkipRebuild"
          BeforeTargets="BeforeBuild"
          Condition="'$(SourceExpander_PackJson_Enabled)' == 'true' And '$(_SourceExpander_Rebuilding)' == 'true'">
    <Message Importance="high" Text="Rebuild without metadata [$(TargetFramework)]" />
    <PropertyGroup>
      <SourceExpander_Embedder_Enabled>false</SourceExpander_Embedder_Enabled>
    </PropertyGroup>
  </Target>

  <!-- Rebuild dll without metadata before pack -->
  <Target Name="SourceExpanderRebuildJsonPackage"
          BeforeTargets="GenerateNuspec"
          Condition="'$(SourceExpander_PackJson_Enabled)' == 'true'">
    <Message Importance="high" Text="SourceExpander: Rebuild '$(AssemblyName)' without metadata" />
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="Build"
             Properties="NoBuild=false;GeneratePackageOnBuild=false;_SourceExpander_Rebuilding=true" />
  </Target>
  <Target Name="SourceExpanderRebuildWithoutMetadata"
          AfterTargets="ResolveAssemblyReferences"
          Condition="'$(SourceExpander_PackJson_Enabled)' == 'true' And '$(_SourceExpander_Rebuilding)' == 'true'">
    <ItemGroup>
      <SourceExpanderAnalyzer Include="@(Analyzer)"
                              Condition="'%(Analyzer.Filename)' == 'SourceExpander.Embedder'" />
    </ItemGroup>
    <GetAssemblyIdentity AssemblyFiles="@(SourceExpanderAnalyzer)">
      <Output TaskParameter="Assemblies" ItemName="SourceExpanderIdentity" />
    </GetAssemblyIdentity>

    <PropertyGroup>
      <SourceExpanderVersion>%(SourceExpanderIdentity.Version)</SourceExpanderVersion>
    </PropertyGroup>

    <Message Text="SourceExpander.Embedder Version: $(SourceExpanderVersion)" Importance="High" />

    <ItemGroup Condition="'$(SourceExpanderVersion)' != ''">
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>SourceExpander.EmbedderVersion</_Parameter1>
            <_Parameter2>$(SourceExpanderVersion)</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>
  </Target>
</Project>