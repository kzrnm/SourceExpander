<Project>
  <PropertyGroup>
    <SourceExpander>true</SourceExpander>
    <SourceExpander_Embedder>true</SourceExpander_Embedder>
    <SourceExpander_Embedder_PackJson>false</SourceExpander_Embedder_PackJson>
    <_ReadEmbeddedDataAssembly>$(MSBuildThisFileDirectory)../tasks/netstandard2.0/SourceExpander.Tasks.dll</_ReadEmbeddedDataAssembly>
  </PropertyGroup>
  <ItemGroup>
    <CompilerVisibleProperty Include="SourceExpander_Embedder_Enabled" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_Include" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_Exclude" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_MinifyLevel" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_EmbeddingType" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_ExcludeAttributes" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_RemoveConditional" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_EmbeddingFileNameType" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_ExpandingSymbol" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_ExpandInLibrary" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_LanguageVersion" />
    <CompilerVisibleProperty Include="SourceExpander_Embedder_EmbeddingSourceClassName" />
  </ItemGroup>
  <UsingTask TaskName="SourceExpander.ReadEmbeddedData" AssemblyFile="$(_ReadEmbeddedDataAssembly)"/>
</Project>
